    private void StartCountdownTimer(int compartmentIndex)
    {
        if (compartmentIndex >= 0 && compartmentIndex < compartments.Count && compartments[compartmentIndex] != null)
        {
            // Get the next medication time
            DateTime nextMedicationTime = compartments[compartmentIndex]!.BerekenVolgendeInnameTijd();
            
            if (nextMedicationTime != DateTime.MaxValue)
            {
                // Set up the countdown variables
                activeCountdownCompartmentIndex = compartmentIndex;
                activeCountdownMedication = compartments[compartmentIndex];
                activeCountdownTime = nextMedicationTime;
                
                // Update the countdown display
                UpdateCountdownDisplay();
                
                // Start or restart the countdown timer
                if (countdownTimer == null)
                {
                    countdownTimer = new Timer(1000);
                    countdownTimer.Elapsed += (sender, e) => InvokeAsync(() => {
                        UpdateCountdownDisplay();
                        StateHasChanged();
                    });
                    countdownTimer.AutoReset = true;
                    countdownTimer.Start();
                }
                else
                {
                    countdownTimer.Start();
                }
                
                // Show the countdown page
                HideAllPages();
                showCountdownPage = true;
                StateHasChanged();
            }
            else
            {
                ShowAlert("Geen Doseringstijden", "Er zijn geen doseringstijden ingesteld voor dit compartiment", "bg-warning");
            }
        }
    }

    private void UpdateCountdownDisplay()
    {
        if (activeCountdownMedication != null)
        {
            TimeSpan remainingTime = activeCountdownTime - DateTime.Now;
            
            if (remainingTime.TotalSeconds <= 0)
            {
                // Time's up!
                countdownDisplay = "Tijd voor medicijn!";
                
                // Stop the timer
                countdownTimer?.Stop();
                
                // Show reminder if not already showing
                if (!showMedicationReminderPage)
                {
                    ShowMedicationReminder(activeCountdownCompartmentIndex);
                }
            }
            else
            {
                // Format the remaining time
                if (remainingTime.Days > 0)
                {
                    countdownDisplay = $"{remainingTime.Days}d {remainingTime.Hours}u {remainingTime.Minutes}m {remainingTime.Seconds}s";
                }
                else if (remainingTime.Hours > 0)
                {
                    countdownDisplay = $"{remainingTime.Hours}u {remainingTime.Minutes}m {remainingTime.Seconds}s";
                }
                else
                {
                    countdownDisplay = $"{remainingTime.Minutes}m {remainingTime.Seconds}s";
                }
            }
        }
    }

