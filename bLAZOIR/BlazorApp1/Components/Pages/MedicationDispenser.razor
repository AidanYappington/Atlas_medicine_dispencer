    private void StartCountdownForNextMedication()
    {
        // Find the compartment with the earliest next dosage
        int nextCompartmentIndex = -1;
        DateTime nextDosageTime = DateTime.MaxValue;
        
        for (int i = 0; i < compartments.Count; i++)
        {
            if (compartments[i] != null)
            {
                DateTime dosageTime = compartments[i]!.BerekenVolgendeInnameTijd();
                
                if (dosageTime < nextDosageTime)
                {
                    nextDosageTime = dosageTime;
                    nextCompartmentIndex = i;
                }
            }
        }
        
        if (nextCompartmentIndex != -1)
        {
            StartCountdownTimer(nextCompartmentIndex);
        }
        else
        {
            ShowAlert("Geen Medicijnen", "Er zijn geen medicijnen geconfigureerd", "bg-warning");
        }
    }

