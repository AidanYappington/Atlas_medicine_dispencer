@page "/medication-dispenser"
@using System
@using System.Collections.Generic
@using System.Timers
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="container">
    <div class="header mb-4">
        <h1 class="text-center p-3 bg-primary text-white rounded">Thuis Medicijn Dispenser</h1>
    </div>

    @if (showMenuPage)
    {
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">Menu</h3>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            <button class="list-group-item list-group-item-action" @onclick="ShowStatus">1. Toon status van alle compartimenten</button>
                            <button class="list-group-item list-group-item-action" @onclick="ShowLogs">2. Medicijninname logboek bekijken</button>
                            <button class="list-group-item list-group-item-action" @onclick="ConfigureCompartment">3. Configureer een compartiment (beheerder)</button>
                            <button class="list-group-item list-group-item-action" @onclick="RefillCompartment">4. Vul een compartiment bij (beheerder)</button>
                            <button class="list-group-item list-group-item-action bg-danger text-white" @onclick="EmergencyUnlock">5. Noodontgrendeling (alleen voor noodgevallen)</button>
                            <button class="list-group-item list-group-item-action" @onclick="TestMedicationReminder">6. Test medicijnherinnering (voor demonstratie)</button>
                            <button class="list-group-item list-group-item-action" @onclick="StartCountdownForNextMedication">7. Toon countdown timer voor volgende medicijn</button>
                            <button class="list-group-item list-group-item-action" @onclick="StartCountdownForSpecificMedication">8. Toon countdown timer voor specifiek medicijn</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showStatusPage)
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Medicijn Dispenser Status</h3>
                <button class="btn btn-light" @onclick="BackToMenu">Terug</button>
            </div>
            <div class="card-body">
                @if (compartments.Count == 0 || compartments.All(c => c == null))
                {
                    <div class="alert alert-warning">
                        <h4>Geen medicijnen geconfigureerd in deze dispenser.</h4>
                        <p>Gebruik optie 3 om medicijncompartimenten te configureren.</p>
                    </div>
                }
                else
                {
                    <div class="row">
                        @for (int i = 0; i < compartments.Count; i++)
                        {
                            var compartment = compartments[i];
                            var index = i;  // Capture the current index
                            
                            <div class="col-md-6 mb-4">
                                <div class="card h-100">
                                    <div class="card-header">
                                        <h4>Compartiment @(index + 1)</h4>
                                    </div>
                                    <div class="card-body">
                                        @if (compartment != null)
                                        {
                                            <p><strong>Medicijn:</strong> @compartment.MedicijnNaam (@compartment.Dosis)</p>
                                            <p><strong>Voorraad:</strong> @compartment.Voorraad tabletten</p>
                                            
                                            <p>
                                                <strong>Status:</strong>
                                                @switch (compartment.Status)
                                                {
                                                    case CompartimentStatus.Vergrendeld:
                                                        <span class="badge bg-danger">VERGRENDELD</span>
                                                        break;
                                                    case CompartimentStatus.Ontgrendeld:
                                                        <span class="badge bg-warning">ONTGRENDELD</span>
                                                        break;
                                                    case CompartimentStatus.Open:
                                                        <span class="badge bg-success">OPEN</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@compartment.Status.ToString()</span>
                                                        break;
                                                }
                                            </p>
                                            
                                            <p><strong>Volgende dosering:</strong> @compartment.VolgendeDoseringstijd()</p>
                                            
                                            <div class="d-flex justify-content-end">
                                                <button class="btn btn-outline-primary btn-sm me-2" @onclick="() => StartCountdownTimer(index)">
                                                    Toon Timer
                                                </button>
                                                <button class="btn btn-outline-success btn-sm" @onclick="() => TriggerMedicijnHerinnering(index)">
                                                    Test Herinnering
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="text-muted">Niet geconfigureerd</p>
                                            <button class="btn btn-primary btn-sm" @onclick="() => ConfigureSpecificCompartment(index)">
                                                Configureren
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (showLogsPage)
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Medicijn Inname Log</h3>
                <button class="btn btn-light" @onclick="BackToMenu">Terug</button>
            </div>
            <div class="card-body">
                @if (innameLogs.Count == 0)
                {
                    <div class="alert alert-info">Geen medicijnen ingenomen.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Tijd</th>
                                    <th>Compartiment</th>
                                    <th>Medicijn</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in innameLogs)
                                {
                                    string medicijnNaam = compartments[log.compartimentNr] != null 
                                        ? compartments[log.compartimentNr].MedicijnNaam 
                                        : "Onbekend";
                                        
                                    string status = log.genomen ? "Genomen" : "Gemist";
                                    
                                    <tr>
                                        <td>@log.tijdstip.ToString("dd-MM-yyyy HH:mm")</td>
                                        <td>@(log.compartimentNr + 1)</td>
                                        <td>@medicijnNaam</td>
                                        <td>
                                            @if (log.genomen)
                                            {
                                                <span class="badge bg-success">Genomen</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Gemist</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    @if (showConfigurePage)
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Compartiment Configuratie</h3>
                <button class="btn btn-light" @onclick="BackToMenu">Terug</button>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="compartment-select" class="form-label">Selecteer compartiment:</label>
                    <select id="compartment-select" class="form-select" @bind="selectedCompartmentIndex">
                        @for (int i = 0; i < compartments.Count; i++)
                        {
                            <option value="@i">Compartiment @(i + 1)</option>
                        }
                    </select>
                </div>
                
                <div class="mb-3">
                    <label for="medication-name" class="form-label">Medicijn naam:</label>
                    <input id="medication-name" type="text" class="form-control" @bind="configMedicationName" />
                </div>
                
                <div class="mb-3">
                    <label for="medication-dosage" class="form-label">Dosering (bijv. 500mg):</label>
                    <input id="medication-dosage" type="text" class="form-control" @bind="configMedicationDosage" />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Doseringstijden:</label>
                    
                    @foreach (var time in configDosingTimes)
                    {
                        var index = configDosingTimes.IndexOf(time);
                        <div class="input-group mb-2">
                            <input type="time" class="form-control" value="@time.ToString(@"hh\:mm")" 
                                @onchange="@(e => UpdateDosingTime(index, e.Value?.ToString()))" />
                            <button class="btn btn-outline-danger" @onclick="() => RemoveDosingTime(index)">
                                <i class="bi bi-trash"></i> Verwijder
                            </button>
                        </div>
                    }
                    
                    <button class="btn btn-outline-primary" @onclick="AddDosingTime">
                        <i class="bi bi-plus"></i> Tijdstip toevoegen
                    </button>
                </div>
                
                <div class="mb-3">
                    <label for="medication-stock" class="form-label">Beginvoorraad:</label>
                    <input id="medication-stock" type="number" class="form-control" @bind="configMedicationStock" min="0" />
                </div>
                
                <div class="d-flex justify-content-end">
                    <button class="btn btn-primary" @onclick="SaveCompartmentConfig">Opslaan</button>
                </div>
            </div>
        </div>
    }

    @if (showRefillPage)
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Compartiment Bijvullen</h3>
                <button class="btn btn-light" @onclick="BackToMenu">Terug</button>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="refill-compartment-select" class="form-label">Selecteer compartiment:</label>
                    <select id="refill-compartment-select" class="form-select" @bind="selectedRefillCompartmentIndex">
                        @for (int i = 0; i < compartments.Count; i++)
                        {
                            if (compartments[i] != null)
                            {
                                <option value="@i">Compartiment @(i + 1) - @compartments[i].MedicijnNaam (@compartments[i].Voorraad stuks)</option>
                            }
                        }
                    </select>
                </div>
                
                <div class="mb-3">
                    <label for="refill-amount" class="form-label">Aantal om toe te voegen:</label>
                    <input id="refill-amount" type="number" class="form-control" @bind="refillAmount" min="1" />
                </div>
                
                <div class="d-flex justify-content-end">
                    <button class="btn btn-primary" @onclick="SaveRefill">Bijvullen</button>
                </div>
            </div>
        </div>
    }

    @if (showCountdownPage)
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Medicijn Countdown Timer</h3>
                <button class="btn btn-light" @onclick="BackToMenu">Terug</button>
            </div>
            <div class="card-body text-center">
                @if (activeCountdownMedication != null)
                {
                    <div class="countdown-display p-4 mb-4 border rounded bg-light">
                        <h2 class="mb-3">@activeCountdownMedication.MedicijnNaam</h2>
                        <p class="mb-2">Compartiment @(activeCountdownCompartmentIndex + 1) - @activeCountdownMedication.Dosis</p>
                        
                        <div class="countdown-timer my-4">
                            <h1 class="display-3 text-primary mb-3">@countdownDisplay</h1>
                            <p>Tijd tot volgende inname</p>
                        </div>
                        
                        <p class="mb-0">Volgende inname: @activeCountdownTime.ToString("dd-MM-yyyy HH:mm")</p>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning">
                        <p>Geen medicijn geselecteerd voor countdown.</p>
                    </div>
                }
            </div>
        </div>
    }

    @if (showMedicationReminderPage)
    {
        <div class="card mb-4 reminder-alert">
            <div class="card-header bg-danger text-white">
                <h3 class="mb-0">MEDICIJN HERINNERING</h3>
            </div>
            <div class="card-body text-center">
                <h2 class="mb-3">Het is tijd om uw medicijn te nemen:</h2>
                
                <div class="medication-info my-4">
                    <h3 class="text-primary">@activeReminderMedication.MedicijnNaam</h3>
                    <p class="lead">@activeReminderMedication.Dosis</p>
                    <p class="mb-4">Compartiment @(activeReminderCompartmentIndex + 1)</p>
                </div>
                
                <div class="d-grid gap-2 col-md-6 mx-auto">
                    <button class="btn btn-success btn-lg mb-2" @onclick="UnlockCompartment">
                        Ontgrendel Compartiment
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="DismissReminder">
                        Later Herinneren
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showCompartmentUnlockedPage)
    {
        <div class="card mb-4">
            <div class="card-header bg-warning text-dark">
                <h3 class="mb-0">COMPARTIMENT ONTGRENDELD</h3>
            </div>
            <div class="card-body text-center">
                <h2 class="mb-3">Compartiment @(activeReminderCompartmentIndex + 1) is ontgrendeld</h2>
                
                <div class="medication-info my-4">
                    <h3 class="text-primary">@activeReminderMedication.MedicijnNaam</h3>
                    <p class="lead">@activeReminderMedication.Dosis</p>
                </div>
                
                <div class="d-grid gap-2 col-md-6 mx-auto">
                    <button class="btn btn-success btn-lg mb-2" @onclick="OpenCompartment">
                        Open Compartiment
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showCompartmentOpenPage)
    {
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h3 class="mb-0">COMPARTIMENT OPEN</h3>
            </div>
            <div class="card-body text-center">
                <h2 class="mb-3">Neem uw medicijn</h2>
                
                <div class="medication-info my-4">
                    <h3 class="text-primary">@activeReminderMedication.MedicijnNaam</h3>
                    <p class="lead">@activeReminderMedication.Dosis</p>
                    <p class="mb-4">Compartiment @(activeReminderCompartmentIndex + 1)</p>
                </div>
                
                <div class="d-grid gap-2 col-md-6 mx-auto">
                    <button class="btn btn-success btn-lg mb-2" @onclick="TakeMedication">
                        Ik heb mijn medicijn genomen
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="CloseCompartmentWithoutTaking">
                        Sluiten zonder medicijn te nemen
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showAlert)
    {
        <div class="position-fixed top-0 start-0 end-0 p-3" style="z-index: 1050;">
            <div class="toast show mx-auto" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header @alertHeaderClass">
                    <strong class="me-auto text-white">@alertTitle</strong>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseAlert"></button>
                </div>
                <div class="toast-body">
                    @((MarkupString)alertMessage)
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Enumeratie voor de status van het dispenser-compartiment
    enum CompartimentStatus
    {
        Vergrendeld,
        Ontgrendeld,
        Open,
        Gesloten
    }
    
    // Enumeratie voor licht-indicaties
    enum LichtStatus
    {
        Uit,
        Rood,
        Groen,
        Geel,
        Knipperend
    }

    // Klasse voor een medicijncompartiment
    class MedicijnCompartiment
    {
        public string MedicijnNaam { get; private set; }
        public string Dosis { get; private set; }
        public int CompartimentNummer { get; private set; }
        public CompartimentStatus Status { get; private set; }
        public LichtStatus Licht { get; private set; }
        public int Voorraad { get; private set; }
        public List<TimeSpan> DoseringstijdenPerDag { get; private set; }
        public DateTime? LaatsteOpeningTijd { get; private set; }

        public MedicijnCompartiment(int nummer, string medicijnNaam, string dosis)
        {
            CompartimentNummer = nummer;
            MedicijnNaam = medicijnNaam;
            Dosis = dosis;
            Status = CompartimentStatus.Vergrendeld;
            Licht = LichtStatus.Uit;
            Voorraad = 0;
            DoseringstijdenPerDag = new List<TimeSpan>();
            LaatsteOpeningTijd = null;
        }

        public void VoegDoseringstijdToe(int uur, int minuut)
        {
            DoseringstijdenPerDag.Add(new TimeSpan(uur, minuut, 0));
        }

        public bool IsHetTijdVoorDosering(DateTime nu)
        {
            TimeSpan huidigeTijd = nu.TimeOfDay;
            
            foreach (TimeSpan doseringstijd in DoseringstijdenPerDag)
            {
                // Controleer of het binnen 5 minuten van een dosering is
                double verschilMinuten = Math.Abs((huidigeTijd - doseringstijd).TotalMinutes);
                
                if (verschilMinuten <= 5)
                {
                    return true;
                }
            }
            
            return false;
        }

        public void VulVoorraadBij(int aantal)
        {
            Voorraad += aantal;
        }

        public bool NeemMedicijn()
        {
            if (Voorraad > 0 && Status == CompartimentStatus.Open)
            {
                Voorraad--;
                LaatsteOpeningTijd = DateTime.Now;
                return true;
            }
            return false;
        }

        public void ZetStatus(CompartimentStatus nieuweStatus)
        {
            Status = nieuweStatus;
            
            // Update licht gebaseerd op nieuwe status
            switch (Status)
            {
                case CompartimentStatus.Vergrendeld:
                    Licht = LichtStatus.Rood;
                    break;
                case CompartimentStatus.Ontgrendeld:
                    Licht = LichtStatus.Knipperend;
                    break;
                case CompartimentStatus.Open:
                    Licht = LichtStatus.Groen;
                    break;
                case CompartimentStatus.Gesloten:
                    Licht = LichtStatus.Uit;
                    break;
            }
        }

        public string VolgendeDoseringstijd()
        {
            if (DoseringstijdenPerDag.Count == 0)
                return "Geen doseringstijden ingesteld";

            DateTime nu = DateTime.Now;
            TimeSpan huidigeTijd = nu.TimeOfDay;
            
            // Zoek het eerstvolgende doseringsmoment
            TimeSpan? volgende = null;
            double kortsteWachttijd = double.MaxValue;
            
            foreach (TimeSpan doseringstijd in DoseringstijdenPerDag)
            {
                // Bereken wachttijd (vandaag of morgen)
                double wachttijdMinuten;
                
                if (doseringstijd > huidigeTijd)
                {
                    // Later vandaag
                    wachttijdMinuten = (doseringstijd - huidigeTijd).TotalMinutes;
                }
                else
                {
                    // Morgen
                    wachttijdMinuten = (TimeSpan.FromHours(24) - huidigeTijd + doseringstijd).TotalMinutes;
                }
                
                if (wachttijdMinuten < kortsteWachttijd)
                {
                    kortsteWachttijd = wachttijdMinuten;
                    volgende = doseringstijd;
                }
            }
            
            if (volgende.HasValue)
            {
                // Bereken datum en tijd van de volgende dosis
                DateTime volgendeDosering;
                
                if (volgende.Value > huidigeTijd)
                {
                    // Later vandaag
                    volgendeDosering = nu.Date.Add(volgende.Value);
                }
                else
                {
                    // Morgen
                    volgendeDosering = nu.Date.AddDays(1).Add(volgende.Value);
                }
                
                return volgendeDosering.ToString("dd-MM HH:mm");
            }
            
            return "Onbekend";
        }
        
        // Bereken de DateTime van de volgende inname
        public DateTime BerekenVolgendeInnameTijd()
        {
            if (DoseringstijdenPerDag.Count == 0)
                return DateTime.MaxValue;

            DateTime nu = DateTime.Now;
            TimeSpan huidigeTijd = nu.TimeOfDay;
            
            // Zoek het eerstvolgende doseringsmoment
            TimeSpan? volgende = null;
            double kortsteWachttijd = double.MaxValue;
            
            foreach (TimeSpan doseringstijd in DoseringstijdenPerDag)
            {
                // Bereken wachttijd (vandaag of morgen)
                double wachttijdMinuten;
                
                if (doseringstijd > huidigeTijd)
                {
                    // Later vandaag
                    wachttijdMinuten = (doseringstijd - huidigeTijd).TotalMinutes;
                }
                else
                {
                    // Morgen
                    wachttijdMinuten = (TimeSpan.FromHours(24) - huidigeTijd + doseringstijd).TotalMinutes;
                }
                
                if (wachttijdMinuten < kortsteWachttijd)
                {
                    kortsteWachttijd = wachttijdMinuten;
                    volgende = doseringstijd;
                }
            }
            
            if (volgende.HasValue)
            {
                // Bereken datum en tijd van de volgende dosis
                if (volgende.Value > huidigeTijd)
                {
                    // Later vandaag
                    return nu.Date.Add(volgende.Value);
                }
                else
                {
                    // Morgen
                    return nu.Date.AddDays(1).Add(volgende.Value);
                }
            }
            
            return DateTime.MaxValue;
        }
    }

    // View state variables
    private bool showMenuPage = true;
    private bool showStatusPage = false;
    private bool showLogsPage = false;
    private bool showConfigurePage = false;
    private bool showRefillPage = false;
    private bool showCountdownPage = false;
    private bool showMedicationReminderPage = false;
    private bool showCompartmentUnlockedPage = false;
    private bool showCompartmentOpenPage = false;
    private bool showAlert = false;
    
    // Alert properties
    private string alertTitle = "";
    private string alertMessage = "";
    private string alertHeaderClass = "bg-primary";
    
    // Dispenser data
    private List<MedicijnCompartiment?> compartments = new List<MedicijnCompartiment?>();
    private List<(int compartimentNr, DateTime tijdstip, bool genomen)> innameLogs = new List<(int, DateTime, bool)>();
    private Timer? checkMedicationsTimer;
    private Timer? countdownTimer;
    
    // Configuration page variables
    private int selectedCompartmentIndex = 0;
    private string configMedicationName = "";
    private string configMedicationDosage = "";
    private List<TimeSpan> configDosingTimes = new List<TimeSpan>();
    private int configMedicationStock = 0;
    
    // Refill page variables
    private int selectedRefillCompartmentIndex = 0;
    private int refillAmount = 1;
    
    // Countdown page variables
    private int activeCountdownCompartmentIndex = -1;
    private MedicijnCompartiment? activeCountdownMedication = null;
    private DateTime activeCountdownTime = DateTime.MaxValue;
    private string countdownDisplay = "--:--:--";
    
    // Reminder page variables
    private int activeReminderCompartmentIndex = -1;
    private MedicijnCompartiment? activeReminderMedication = null;

    protected override void OnInitialized()
    {
        // Initialize the dispenser with 4 empty compartments
        for (int i = 0; i < 4; i++)
        {
            compartments.Add(null);
        }
        
        // Start the timer to check medication schedules every minute
        checkMedicationsTimer = new Timer(60000); // 60 seconds
        checkMedicationsTimer.Elapsed += CheckMedicationsTimerElapsed;
        checkMedicationsTimer.AutoReset = true;
        checkMedicationsTimer.Start();
        
        // Set up example medications if needed
        SetupVoorbeeldDispenser();
    }

    protected async override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Optional: perform any JavaScript initialization
            await JSRuntime.InvokeVoidAsync("console.log", "Medication Dispenser initialized");
        }
    }

    private void SetupVoorbeeldDispenser()
    {
        // Compartiment 1: Paracetamol (3x daags)
        ConfigureerCompartiment(0, "Paracetamol", "500mg");
        
        // Morning, afternoon, evening dosage times
        compartments[0]?.VoegDoseringstijdToe(8, 0);
        compartments[0]?.VoegDoseringstijdToe(13, 0);
        compartments[0]?.VoegDoseringstijdToe(20, 0);
        
        compartments[0]?.VulVoorraadBij(30);
        
        // Compartiment 2: Vitamine D (1x daags)
        ConfigureerCompartiment(1, "Vitamine D", "25mcg");
        compartments[1]?.VoegDoseringstijdToe(8, 0);
        compartments[1]?.VulVoorraadBij(60);
        
