    private void ConfigureerCompartiment(int compartimentNr, string medicijnNaam, string dosis)
    {
        if (compartimentNr >= 0 && compartimentNr < compartments.Count)
        {
            compartments[compartimentNr] = new MedicijnCompartiment(compartimentNr + 1, medicijnNaam, dosis);
        }
    }

    private void CheckMedicationsTimerElapsed(object? sender, ElapsedEventArgs e)
    {
        // Check if any medication needs to be taken
        DateTime now = DateTime.Now;
        bool medicationNeeded = false;
        
        for (int i = 0; i < compartments.Count; i++)
        {
            if (compartments[i] != null && 
                compartments[i]!.IsHetTijdVoorDosering(now) && 
                compartments[i]!.Status == CompartimentStatus.Vergrendeld)
            {
                InvokeAsync(() => {
                    ShowMedicationReminder(i);
                    PlayAlertSound();
                });
                
                medicationNeeded = true;
                break;
            }
        }
        
        if (!medicationNeeded)
        {
            // Update the countdown timer if active
            if (activeCountdownMedication != null)
            {
                InvokeAsync(() => {
                    UpdateCountdownDisplay();
                    StateHasChanged();
                });
            }
        }
    }
    
    private async Task PlayAlertSound()
    {
        try
        {
            // Play notification sound using browser API
            await JSRuntime.InvokeVoidAsync("eval", @"
                function beep() {
                    var snd = new Audio('data:audio/wav;base64,');  
                    snd.play();
                }
                try {
                    beep();
                    setTimeout(beep, 500);
                    setTimeout(beep, 1000);
                } catch(e) {
                    console.error('Sound error:', e);
                }
            ");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error playing sound: {ex.Message}");
        }
    }

